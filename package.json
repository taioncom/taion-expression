{
  "name": "@taioncom/taion-expression",
  "version": "1.2.0",
  "description": "A safe, sandboxed expression evaluator for JavaScript/TypeScript with large set of built-in functions",
  "author": "Taion <info@taion.com>",
  "copyright": "Copyright (c) 2026 Taion Oy",
  "private": false,
  "license": "MIT",
  "keywords": [
    "expression",
    "evaluator",
    "sandbox",
    "parser",
    "safe",
    "ast"
  ],
  "main": "build/main/index.js",
  "typings": "build/main/index.d.ts",
  "module": "build/module/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./build/module/index.d.ts",
        "default": "./build/module/index.js"
      },
      "require": {
        "types": "./build/main/index.d.ts",
        "default": "./build/main/index.js"
      }
    }
  },
  "homepage": "https://taioncom.github.io/taion-expression/",
  "repository": "https://github.com/taioncom/taion-expression",
  "scripts": {
    "build": "run-p build:*",
    "build:main": "tsc -p tsconfig.json",
    "build:module": "tsc -p tsconfig.module.json && echo '{\"type\":\"module\"}' > build/module/package.json",
    "fix": "run-s fix:*",
    "fix:prettier": "prettier \"src/**/*.ts\" --write",
    "fix:lint": "eslint src --ext .ts --fix --config eslint.config.mjs",
    "test": "run-s build test:*",
    "test:lint": "eslint src --ext .ts --config eslint.config.mjs",
    "test:unit": "jest",
    "test:prettier": "prettier \"src/**/*.ts\" --check",
    "test:smoke": "node tests/smoke.cjs && node tests/smoke.mjs",
    "watch:build": "tsc -p tsconfig.json -w",
    "watch:test": "jest --watch",
    "cov": "jest --coverage",
    "cov:lcov": "jest --coverage --coverageReporters=lcov",
    "cov:check": "jest --coverage --coverageThreshold='{\"global\":{\"lines\":95,\"functions\":95,\"branches\":80}}'",
    "prepack": "run-s build test:lint test:prettier test:unit test:smoke",
    "prepublishOnly": "run-s build test:lint test:prettier test:unit test:smoke",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "10.0.1",
    "@jest/globals": "30.2.0",
    "@types/node": "25.3.5",
    "babel-jest": "30.2.0",
    "cross-env": "10.1.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
    "globals": "17.4.0",
    "jest": "30.2.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "@types/jest": "30.0.0",
    "typescript-eslint": "8.56.1"
  },
  "files": [
    "build/main",
    "build/module",
    "!**/*.spec.*",
    "!**/tsconfig.json",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "prettier": {
    "singleQuote": true
  }
}
